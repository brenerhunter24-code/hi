const player = {
  x: canvas.width / 2,
  y: canvas.height / 2,
  size: 30,
  speed: 6
};

const keys = {};
document.addEventListener("keydown", e => keys[e.key] = true);
document.addEventListener("keyup", e => keys[e.key] = false);

let hazards = [];

function randomDisaster() {
  const list = [
    "Tornado",
    "Meteor Shower",
    "Earthquake",
    "Fire Wave",
    "Poison Gas",
    "Lightning Storm"
  ];
  return list[Math.floor(Math.random() * list.length)];
}

function triggerDisaster() {
  currentDisaster = randomDisaster();
  document.getElementById("disaster").textContent = currentDisaster;
  hazards = [];

  if (currentDisaster === "Tornado") spawnTornado();
  if (currentDisaster === "Meteor Shower") spawnMeteors();
  if (currentDisaster === "Earthquake") shakeScreen();
  if (currentDisaster === "Fire Wave") spawnFireWave();
  if (currentDisaster === "Poison Gas") spawnGas();
  if (currentDisaster === "Lightning Storm") spawnLightning();
}

function spawnTornado() {
  hazards.push({
    type: "tornado",
    x: Math.random() * canvas.width,
    y: Math.random() * canvas.height,
    r: 80,
    vx: (Math.random() - 0.5) * 4,
    vy: (Math.random() - 0.5) * 4
  });
}

function spawnMeteors() {
  for (let i = 0; i < 10; i++) {
    hazards.push({
      type: "meteor",
      x: Math.random() * canvas.width,
      y: -100,
      r: 20 + Math.random() * 20,
      vy: 6 + Math.random() * 4
    });
  }
}

