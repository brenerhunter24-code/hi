<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Shadow Maze</title>
<style>
  body {
    margin: 0;
    background: #000;
    overflow: hidden;
    font-family: Arial, sans-serif;
    color: white;
  }
  #msg {
    position: absolute;
    top: 10px;
    left: 10px;
    font-size: 20px;
  }
</style>
</head>
<body>

<div id="msg">Find the exit. Don’t let it see you.</div>
<canvas id="game"></canvas>

<script>
const canvas = document.getElementById("game");
const ctx = canvas.getContext("2d");
canvas.width = window.innerWidth;
canvas.height = window.innerHeight;

// Maze grid
const size = 40;
const cols = Math.floor(canvas.width / size);
const rows = Math.floor(canvas.height / size);

// Generate maze (simple random walls)
let maze = [];
for (let y = 0; y < rows; y++) {
  maze[y] = [];
  for (let x = 0; x < cols; x++) {
    maze[y][x] = Math.random() < 0.2 ? 1 : 0; // 1 = wall
  }
}

// Player
let player = {
  x: 1,
  y: 1,
  r: size * 0.4
};

// Exit
let exit = {
  x: cols - 2,
  y: rows - 2
};

// Monster
let monster = {
  x: Math.floor(cols / 2),
  y: Math.floor(rows / 2),
  speed: 1
};

const keys = {};
document.addEventListener("keydown", e => keys[e.key] = true);
document.addEventListener("keyup", e => keys[e.key] = false);

function movePlayer() {
  let nx = player.x;
  let ny = player.y;

  if (keys["w"] || keys["ArrowUp"]) ny--;
  if (keys["s"] || keys["ArrowDown"]) ny++;
  if (keys["a"] || keys["ArrowLeft"]) nx--;
  if (keys["d"] || keys["ArrowRight"]) nx++;

  if (maze[ny] && maze[ny][nx] === 0) {
    player.x = nx;
    player.y = ny;
    moveMonster();
  }
}

function moveMonster() {
  const dx = player.x - monster.x;
  const dy = player.y - monster.y;

  const stepX = dx === 0 ? 0 : dx / Math.abs(dx);
  const stepY = dy === 0 ? 0 : dy / Math.abs(dy);

  // Monster moves 1 step toward player
  const mx = monster.x + stepX;
  const my = monster.y + stepY;

  if (maze[my] && maze[my][mx] === 0) {
    monster.x = mx;
    monster.y = my;
  }
}

function checkGameOver() {
  if (player.x === monster.x && player.y === monster.y) {
    alert("The shadow found you...");
    location.reload();
  }

  if (player.x === exit.x && player.y === exit.y) {
    alert("You escaped the maze!");
    location.reload();
  }
}

function draw() {
  ctx.clearRect(0, 0, canvas.width, canvas.height);

  // Darkness overlay
  ctx.fillStyle = "black";
  ctx.fillRect(0, 0, canvas.width, canvas.height);

  // Light radius
  const px = player.x * size + size / 2;
  const py = player.y * size + size / 2;

  const gradient = ctx.createRadialGradient(px, py, 20, px, py, 200);
  gradient.addColorStop(0, "rgba(255,255,255,1)");
  gradient.addColorStop(1, "rgba(0,0,0,0)");
  ctx.globalCompositeOperation = "destination-out";
  ctx.fillStyle = gradient;
  ctx.fillRect(px - 200, py - 200, 400, 400);
  ctx.globalCompositeOperation = "source-over";

  // Draw maze
  ctx.fillStyle = "#222";
  for (let y = 0; y < rows; y++) {
    for (let x = 0; x < cols; x++) {
      if (maze[y][x] === 1) {
        ctx.fillRect(x * size, y * size, size, size);
      }
    }
  }

  // Exit
  ctx.fillStyle = "#00ff88";
  ctx.fillRect(exit.x * size, exit.y * size, size, size);

  // Monster (only visible if close)
  const dist = Math.hypot(player.x - monster.x, player.y - monster.y);
  if (dist < 6) {
    ctx.fillStyle = "#ff0033";
    ctx.beginPath();
    ctx.arc(monster.x * size + size/2, monster.y * size + size/2, size/2, 0, Math.PI * 2);
    ctx.fill();
  }

  // Player
  ctx.fillStyle = "#00eaff";
  ctx.beginPath();
  ctx.arc(px, py, player.r, 0, Math.PI * 2);
  ctx.fill();
}

function loop() {
  movePlayer();
  checkGameOver();
  draw();
  requestAnimationFrame(loop);
}

loop();
</script>

</body>
</html>
