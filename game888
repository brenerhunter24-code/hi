<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Blade Arena</title>
<style>
  body {
    margin: 0;
    background: #111;
    overflow: hidden;
    font-family: Arial, sans-serif;
    color: white;
  }
  #ui {
    position: absolute;
    top: 10px;
    left: 10px;
    font-size: 22px;
  }
</style>
</head>
<body>

<div id="ui">Survived: <span id="time">0.0</span>s</div>
<canvas id="game"></canvas>

<script>
const canvas = document.getElementById("game");
const ctx = canvas.getContext("2d");
canvas.width = window.innerWidth;
canvas.height = window.innerHeight;

let time = 0;
let playing = true;

const keys = {};
document.addEventListener("keydown", e => keys[e.key] = true);
document.addEventListener("keyup", e => keys[e.key] = false);

const player = {
  x: canvas.width / 2,
  y: canvas.height / 2,
  size: 40,
  speed: 6,
  attacking: false,
  attackTimer: 0
};

let enemies = [];

function spawnEnemy() {
  const side = Math.floor(Math.random() * 4);
  let x, y;

  if (side === 0) { x = -50; y = Math.random() * canvas.height; }
  if (side === 1) { x = canvas.width + 50; y = Math.random() * canvas.height; }
  if (side === 2) { x = Math.random() * canvas.width; y = -50; }
  if (side === 3) { x = Math.random() * canvas.width; y = canvas.height + 50; }

  enemies.push({
    x,
    y,
    size: 35,
    speed: 2 + Math.random() * 2
  });
}

function updatePlayer() {
  if (keys["w"] || keys["ArrowUp"]) player.y -= player.speed;
  if (keys["s"] || keys["ArrowDown"]) player.y += player.speed;
  if (keys["a"] || keys["ArrowLeft"]) player.x -= player.speed;
  if (keys["d"] || keys["ArrowRight"]) player.x += player.speed;

  player.x = Math.max(0, Math.min(canvas.width - player.size, player.x));
  player.y = Math.max(0, Math.min(canvas.height - player.size, player.y));

  if ((keys[" "] || keys["Enter"]) && !player.attacking) {
    player.attacking = true;
    player.attackTimer = 15;
  }

  if (player.attacking) {
    player.attackTimer--;
    if (player.attackTimer <= 0) player.attacking = false;
  }
}

function updateEnemies() {
  for (const e of enemies) {
    const dx = player.x - e.x;
    const dy = player.y - e.y;
    const len = Math.hypot(dx, dy);
    e.x += (dx / len) * e.speed;
    e.y += (dy / len) * e.speed;
  }
}

function checkCollisions() {
  for (let i = enemies.length - 1; i >= 0; i--) {
    const e = enemies[i];
    const dist = Math.hypot(player.x - e.x, player.y - e.y);

    if (dist < player.size && !player.attacking) {
      gameOver();
    }

    if (player.attacking && dist < player.size + 30) {
      enemies.splice(i, 1);
    }
  }
}

function gameOver() {
  playing = false;
  alert("You survived " + time.toFixed(2) + " seconds!");
  location.reload();
}

function draw() {
  ctx.clearRect(0, 0, canvas.width, canvas.height);

  // player
  ctx.fillStyle = "#00eaff";
  ctx.fillRect(player.x, player.y, player.size, player.size);

  // sword slash
  if (player.attacking) {
    ctx.strokeStyle = "#ffff00";
    ctx.lineWidth = 6;
    ctx.beginPath();
    ctx.arc(player.x + player.size/2, player.y + player.size/2, 60, 0, Math.PI * 2);
    ctx.stroke();
  }

  // enemies
  ctx.fillStyle = "#ff0033";
  for (const e of enemies) {
    ctx.fillRect(e.x, e.y, e.size, e.size);
  }
}

let lastSpawn = 0;
let lastTime = performance.now();

function loop(t) {
  if (!playing) return;

  const dt = (t - lastTime) / 1000;
  lastTime = t;

  time += dt;
  document.getElementById("time").textContent = time.toFixed(1);

  updatePlayer();
  updateEnemies();
  checkCollisions();

  if (t - lastSpawn > 700) {
    spawnEnemy();
    lastSpawn = t;
  }

  draw();
  requestAnimationFrame(loop);
}

loop(lastTime);
</script>

</body>
</html>
