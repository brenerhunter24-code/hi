<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Color Swap Dodge</title>
<style>
  body {
    margin: 0;
    background: #111;
    overflow: hidden;
    font-family: Arial, sans-serif;
    color: white;
  }
  #score {
    position: absolute;
    top: 10px;
    left: 10px;
    font-size: 22px;
  }
</style>
</head>
<body>

<div id="score">Score: 0</div>
<canvas id="game"></canvas>

<script>
const canvas = document.getElementById("game");
const ctx = canvas.getContext("2d");
canvas.width = window.innerWidth;
canvas.height = window.innerHeight;

let score = 0;
let playing = true;

const player = {
  x: canvas.width / 2,
  y: canvas.height - 120,
  r: 30,
  color: "blue"
};

let obstacles = [];

document.addEventListener("keydown", e => {
  if (e.key === "a" || e.key === "ArrowLeft") player.x -= 40;
  if (e.key === "d" || e.key === "ArrowRight") player.x += 40;
  if (e.key === " " || e.key === "w" || e.key === "ArrowUp") {
    player.color = player.color === "blue" ? "orange" : "blue";
  }
});

function spawnObstacle() {
  const size = 80;
  obstacles.push({
    x: Math.random() * (canvas.width - size),
    y: -size,
    w: size,
    h: size,
    color: Math.random() < 0.5 ? "blue" : "orange",
    speed: 4 + Math.random() * 3
  });
}

function update() {
  if (Math.random() < 0.03) spawnObstacle();

  for (const o of obstacles) {
    o.y += o.speed;
  }

  obstacles = obstacles.filter(o => o.y < canvas.height + 200);

  score++;
  document.getElementById("score").textContent = "Score: " + score;

  checkCollision();
}

